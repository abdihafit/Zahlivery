rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /menu_items/{hotelId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == hotelId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
